[Unit]
Description=STUDY1409 Flask App
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/root/app-pwa/STUDY1409-App
EnvironmentFile=/root/app-pwa/STUDY1409-App/.env
ExecStart=/usr/bin/python3 /root/app-pwa/STUDY1409-App/main.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
